generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ ENUMS ============

enum UserRole {
  ADMIN
  PANELIST
  STUDENT
}

enum InterviewMode {
  ONLINE
  OFFLINE
  ON_PAPER
  GOOGLE_DOCS
  CODING_PLATFORM
  HYBRID
}

enum RoundType {
  ONLINE_ASSESSMENT
  TECHNICAL_1
  TECHNICAL_2
  TECHNICAL_3
  SYSTEM_DESIGN
  MANAGERIAL
  HR
  DIRECTOR
  BEHAVIORAL
  CODING_ROUND
  OTHER
}

enum RoundOutcome {
  CLEARED
  REJECTED
  PENDING
  NO_SHOW
}

enum Branch {
  CSE
  IT
  ECE
  EEE
  MECH
  CIVIL
  CHEM
  AI_ML
  OTHER
}

enum ImportStatus {
  QUEUED
  EXTRACTING
  READY_FOR_REVIEW
  APPROVED
  PUBLISHED
  FAILED
}

// ============ CORE ============

model Company {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  logoUrl     String?
  websiteUrl  String?
  description String?
  createdAt   DateTime    @default(now())
  interviews  Interview[]

  @@index([slug])
}

model RoleLevel {
  id         String      @id @default(cuid())
  name       String      @unique
  slug       String      @unique
  createdAt  DateTime    @default(now())
  interviews Interview[]
}

model Interview {
  id                  String     @id @default(cuid())
  company             Company    @relation(fields: [companyId], references: [id])
  companyId           String
  role                String
  roleLevel           RoleLevel  @relation(fields: [roleLevelId], references: [id])
  roleLevelId         String
  year                Int
  totalSelected       Int?
  biggestTip          String?
  candidateCgpa       Float?
  candidateBranch     Branch?
  candidateGradYear   Int?
  candidateBackground String?
  publishedAt         DateTime   @default(now())
  createdBy           User       @relation(fields: [createdById], references: [id])
  createdById         String

  rounds              Round[]
  assets              Asset[]
  bookmarks           Bookmark[]
  importedFrom        ImportRow? @relation("ImportToInterview")

  @@index([companyId, roleLevelId, year])
  @@index([roleLevelId])
  @@index([year])
  @@index([publishedAt])
  @@index([candidateBranch])
}

model Round {
  id              String           @id @default(cuid())
  interview       Interview        @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewId     String
  roundNumber     Int
  roundName       String
  roundType       RoundType
  durationMinutes Int?
  mode            InterviewMode
  numInterviewers Int?
  interviewStyle  String?
  outcome         RoundOutcome
  keyLearnings    String?

  topicCoverages  TopicCoverage[]
  assets          Asset[]

  @@index([interviewId, roundNumber])
  @@index([roundType])
}

// ============ TOPIC AREAS & SUB-TOPICS ============

model TopicArea {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())

  subTopics      SubTopic[]
  topicCoverages TopicCoverage[]

  @@index([sortOrder])
}

model SubTopic {
  id            String           @id @default(cuid())
  name          String
  slug          String
  topicArea     TopicArea        @relation(fields: [topicAreaId], references: [id])
  topicAreaId   String
  createdAt     DateTime         @default(now())

  entries       SubTopicEntry[]

  @@unique([slug, topicAreaId])
  @@unique([name, topicAreaId])
  @@index([topicAreaId])
}

model TopicCoverage {
  id              String          @id @default(cuid())
  round           Round           @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId         String
  topicArea       TopicArea       @relation(fields: [topicAreaId], references: [id])
  topicAreaId     String
  subTopicCount   Int             @default(0)
  orderIndex      Int             @default(0)

  entries         SubTopicEntry[]

  @@index([roundId, orderIndex])
  @@index([topicAreaId])
}

model SubTopicEntry {
  id                 String        @id @default(cuid())
  topicCoverage      TopicCoverage @relation(fields: [topicCoverageId], references: [id], onDelete: Cascade)
  topicCoverageId    String
  subTopic           SubTopic      @relation(fields: [subTopicId], references: [id])
  subTopicId         String
  orderIndex         Int           @default(0)
  exactQuestionText  String?
  referenceUrl       String?

  @@index([topicCoverageId, orderIndex])
  @@index([subTopicId])
}

// ============ ASSETS ============

model Asset {
  id          String     @id @default(cuid())
  interview   Interview? @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewId String?
  round       Round?     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId     String?
  kind        String
  url         String
  label       String?
  uploadedAt  DateTime   @default(now())

  @@index([interviewId])
  @@index([roundId])
}

// ============ USERS ============

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  role         UserRole      @default(STUDENT)
  branch       Branch?
  gradYear     Int?
  avatarUrl    String?
  onboardedAt  DateTime?
  createdAt    DateTime      @default(now())

  interviews   Interview[]
  bookmarks    Bookmark[]
  importBatches ImportBatch[]
}

model Bookmark {
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewId String
  createdAt   DateTime  @default(now())

  @@id([userId, interviewId])
  @@index([interviewId])
}

// ============ CSV IMPORT ============

model ImportBatch {
  id           String      @id @default(cuid())
  uploadedBy   User        @relation(fields: [uploadedById], references: [id])
  uploadedById String
  filename     String
  totalRows    Int
  createdAt    DateTime    @default(now())

  rows         ImportRow[]

  @@index([uploadedById, createdAt])
}

model ImportRow {
  id                    String       @id @default(cuid())
  batch                 ImportBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId               String
  rowIndex              Int
  companyName           String
  status                ImportStatus @default(QUEUED)
  rawCsvJson            Json
  extractedJson         Json?
  extractionTokens      Int?
  extractionCostUsd     Float?
  errorMessage          String?
  publishedInterview    Interview?   @relation("ImportToInterview", fields: [publishedInterviewId], references: [id])
  publishedInterviewId  String?      @unique
  reviewedAt            DateTime?
  updatedAt             DateTime     @updatedAt

  @@index([batchId, status])
  @@index([status])
}

// ============ FEATURE FLAGS ============

model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
}
